# Copia questo file in docker/.env e sostituisci i valori con quelli reali.
# Il file docker/.env NON deve mai essere committato su git.

POSTGRES_DB=notesync
POSTGRES_USER=notesync_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# Per uso locale con Docker Compose il host è "postgres" (nome servizio)
DB_URL=jdbc:postgresql://postgres:5432/notesync
DB_USER=notesync_user
DB_PASS=CHANGE_ME_strong_password_here

# Stringa random di almeno 32 caratteri
JWT_SECRET=CHANGE_ME_minimum_32_random_characters_here
